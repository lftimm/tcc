! ---------------------------------------------------------------------------                                  
! --------------------------------------------------------------------------- 
! ------ BLOCO "B" ------ BLOCO "B" ------ BLOCO "B" ------ BLOCO "B" -------
! ---------------------------------------------------------------------------
!                        || LEITURA DE DADOS ||
! ---------------------------------------------------------------------------
     
! DADOS DA MALHA - contornos solidos e contornos de Neumann 
! -----------------------------------------------------------

! LCONTCARA -	n�mero de faces de elementos com condi��o de contorno de Neumann
!                               (Eq Mom. ou Temp.) N�o l� para as duas equa��es!!   !XXXX 

CALL CPU_TIME(time_i)

LCONTCARA=NCMAX

NBUd = NBU; NBVd = NBV; NBWd = NBW; NBPd = NBP

! ARQUIVO "inicia.par" - PARAMETROS DE inicializa��o 
! ----------------------------------------------------
      
OPEN(2,FILE='inicia.par',STATUS='OLD')
  REWIND (2)

  READ(2,*) PNAME
  READ(2,*) NCOEF 
  READ(2,*) NIR
  READ(2,*) NTR
  READ(2,*) NFILE
  READ(2,*) DtMAX
  READ(2,*) TPOAC
  READ(2,*) TOLTPO
  READ(2,*) NROTPO
  READ(2,*) CSEGUR
  READ(2,*) CONTROL1
  READ(2,*) NPASS
  READ(2,*) INDTURB
  READ(2,*) ELUMP1
  READ(2,*) ELUMP2			!XXXX
  READ(2,*) ELUMP3			!XXXXM
  READ(2,*)	tBlock   
CLOSE(2)

! ***************************************************************************
!                          DEFINICAO DOS PARAMETROS
! ***************************************************************************

! 1 PNAME:    Nome do projeto
! 2 NCOEF:    Nro de intervalos entre registros de coefs. aerodinamicos;
! 3 NIR:      Nro de intervalos entre registros;
! 4 NTR:      Nro total de registros; 
! 5 NFILE:    Nro do ultimo registro;
! 6 DtMAX:    Estimativa inicial para o incremento de tempo;
! 7 TPOAC:    Tempo atual;
! 8 TOLTPO:   Tolerancia para o residuo ( Termino da Simulacao );
! 9 NROTPO:    Numero de passos de tempo apos atingir a tolerancia para o 
!           residuo para considerar-se o estado estacionario alcancado;
! 10 CSEGUR:   Coeficiente de seguranca para determinar o incremento de tempo;
! 11 CONTROL1  Parametro de controle para zerar ou nao alguma variavel. Pode
!           assumir os valores 0.0D+00 ou 1.0D+00.
! 12 NPASS:    N�mero de passos de tempo a partir do qual ser�o calculados os
!           campos m�dios de velocidade e press�o. NPASSMED = NTR*NIR - NPASS
!           ser� o valor tomado para o c�lculo da m�dia. Para o caso em que
!           n�o se deseje este c�lculo, usa-se NPASS = NTR*NIR
! 13 INDTURB:  Indica se ser� ou n�o usado algum modelo de turbul�ncia na
!           an�lise e, caso seja, faz a escolha entre os modelos CL�SSICO e
!           DIN�MICO de SMAGORINSKY para as sub-escalas com simula��o direta
!           para as grandes escalas, de acordo com os seguintes �ndices:
!   INDTURB = 0  --->  an�lise sem a presen�a da turbul�ncia;
!   INDTURB = 1  --->  an�lise com turbul�ncia e modelo sub-malha CL�SSICO;
!   INDTURB = 2  --->  an�lise com turbul�ncia e modelo sub-malha DIN�MICO; 
! 14 ELUMP1:    parametro seletivo de massa (norm adotado 0,9) na equa��o de continuidade
! 15 ELUMP2:    parametro seletivo de massa (norm adotado 0,9) na equa��o de energia		!XXXX
! 16 ELUMP3:    parametro seletivo de massa (norm adotado 0,9) na equa��o de esp�cie		!XXXXM
! 17 tBlock: N�mero de threads por bloco de processamento
! ***************************************************************************
! ***************************************************************************

NNAUX = NTR*NIR
NPASSMED = NNAUX - NPASS - NFILE*NIR  !alterado NFILE XXXX 05.01.12 para m�dia, corrigido 06.01.12 NFILE*NIR
PASSMED = DFLOAT(NPASSMED)      

! ***************************************************************************
!   Atribui-se a variavel "PNAME" aos 6 1ros caracteres da variavel "PTNAME" 
! ***************************************************************************
     
PTNAME(1:6)=PNAME

!        ARQUIVO '.pro' - PROPRIEDADES DO FLUIDO, DO FLUXO E DIMENS�ES
!       ---------------------------------------------------------------
!                 CARACTER�STICAS DO(S) CORPO(S) IMERSO(S)
!                ------------------------------------------

! ***************************************************************************
!  Atribui-se a extensao ".pro" aos 4 ultimos caracteres da variavel "PTNAME"
! ***************************************************************************

! NPSZ - vari�veis que n�o podem receber valor 0.0 pois aparecem no denominador

 PTNAME(7:14)='.pro    '
      
OPEN(2,FILE=PTNAME,STATUS='OLD')
  
  REWIND (2)
  READ(2,*) VInf		!1	
  READ(2,*) VelSom		!2			
  READ(2,*) ViscCin		!3
  READ(2,*) ViscVol		!4
  READ(2,*) RHOInf		!6
  READ(2,*) Cv			!8 NPSZ XXXX  
  READ(2,*) Kdif		!9 NPSZ XXXX 

  READ(2,*) Cs			!12ALTERADO DEBORAH 26.04.11 - ANTES: IF(INDTURB.EQ.1) READ(2,*) Cs
  READ(2,*) Prtlt       !13 NPSZ !ALTERADO 24.11.11 Kdift   				            !XXXXM
     
  READ(2,*) Dab			!15 NPSZ											            !XXXXM

  IF(MNOBJ.NE.0) THEN
      
    DO NOB=1,MNOBJ

      READ(2,*) Lchar(NOB) !17
      READ(2,*) Dchar(NOB) !18	
      READ(2,*) Xobj(NOB)  !19
      READ(2,*) Yobj(NOB)  !20
      READ(2,*) Zobj(NOB)  !21
      READ(2,*) NFCN(NOB)
	  READ(2,*) NNCN(NOB) !22

    END DO

  END IF
            
CLOSE(2)

! Pdin � a press�o din�mica baseada na velocidade de corrente n�o perturbada (Vinf):

Pdin = 0.5D0*RHOInf*Vinf*Vinf

! ***************************************************************************
!                          DEFINICAO DAS PROPRIEDADES
!
! Vinf:    1  Modulo do vetor velocidade da corrente nao perturbada (Infinito).
! VelSom:  2  Velocidade de propaga��o do som;
! ViscCin: 3  Viscosidade cinematica do fluido [m^2/s];
! ViscVol: 4  Viscosidade Volumetrica por unidade de massa especifica do fluido [m^2/s];
! RHOInf:  6  Densidade do fluido;
! Cv:      8  Calor especifico a volume constante;
! Kdif:    9  Coeficiente de condutividade termica;
! Cs:      12  Coeficiente de Smagorinsky (valores usuais de 0.1 a 0.22).
!              V�lido somente para o modelo cl�ssico de Smagorinsky (INDTURB=1).
! Kdift:   13  Coeficiente de condutividade termica turbulenta;					    !XXXXM
! Dab:	   15 Coeficiente de difusividade m�ssica;									!XXXXM
! Lchar:   17 Comprimento caracter�stico do corpo imerso NOB;
! Dchar:   18 Dimens�o caracter�stica do corpo imerso NOB
! (X,Y,Z)obj: 19,20 E 21 Coordenadas do centro de massa do corpo imerso NOB
! NFCN,NNCN: 22 N�mero de faces e de n�s de contorno do corpo NOB   
! ***************************************************************************

!            ARQUIVO '.con' - CONETIVIDADES DOS ELEMENTOS
!            --------------------------------------------

! ***************************************************************************
! Atribui-se a extensao ".con" aos 4 ultimos caracteres da variavel "PTNAME"
! ***************************************************************************

PTNAME(7:14)='.con    '
OPEN (2,FILE=PTNAME,STATUS='OLD')

  REWIND (2)
  READ(2,*) NELEM      
  DO I=1,NELEM                                                        
    II=8*(I-1)
    READ(2,*) KONE(II+1),KONE(II+2),KONE(II+3),KONE(II+4),&
              KONE(II+5),KONE(II+6),KONE(II+7),KONE(II+8) 
  END DO
    
CLOSE(2)

write(*,*) "Passou .con"

