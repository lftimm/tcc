!***************************************************************
!***************************************************************
! INICIALIZA��O OPENMP - Identifica��o de n�cleos dispon�veis
!***************************************************************
!ncore = OMP_GET_NUM_PROCS()
!write(*,*) ncore
!PAUSE

!icore = OMP_GET_THREAD_NUM()+1
!write(*,*) icore
!PAUSE

!ncore=1     !novo para teste
!call OMP_SET_NUM_THREADS(ncore)    
