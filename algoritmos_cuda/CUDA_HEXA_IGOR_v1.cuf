ALLOCATE(SmodE_d(NEMAX), FILTR1_d(NEMAX))
ALLOCATE(Pij1_d(NEMAX+1), Pij2_d(NEMAX+1), Pij3_d(NEMAX+1), Pij4_d(NEMAX+1), Pij5_d(NEMAX+1), Pij6_d(NEMAX+1))
ALLOCATE(Psij_d(6,NNOS), uvwf_d(3,NNOS), Pfij_d(6,NNOS), Sfij_d(6,NNOS), FILTR2_d(NNOS), Cxt_d(NNOS))
		 	 
ALLOCATE(TB1_d(8,8), TB2_d(8,8), TB3_d(8,8), BB1_d(8,8), BB2_d(8,8), BB3_d(8,8), dd11_d(8,8), &
         dd12_d(8,8), dd13_d(8,8), dd21_d(8,8), dd22_d(8,8), dd23_d(8,8), dd31_d(8,8), &
		 dd32_d(8,8), dd32_d(8,8), dd33_d(8,8), hourg_d(8,8), mmm_d(8,8), DETERJ_d(NEMAX))

ALLOCATE(rru_d(NEMAX+1,9), rrv_d(NEMAX+1,9), rrw_d(NEMAX+1,9), rrp_d(NEMAX+1,9))
		 
ALLOCATE(FF1f_d(0:NEMAX,0:8), FF2f_d(0:NEMAX,0:8), FF3f_d(0:NEMAX,0:8))		 
		 
ALLOCATE(rrg_d(4,NNOS), uvwa_d(4,NNOS))	
!ALLOCATE(mlum_d(NNOS), rrg_d(6,NNOS), uvwa_d(4,NNOS))	

ALLOCATE(cru_d(NEMAX+1,9), crv_d(NEMAX+1,9), crw_d(NEMAX+1,9))	

ALLOCATE(crug_d(NNOS), crvg_d(NNOS), crwg_d(NNOS)) 
		 
ALLOCATE(PPROME_d(NEMAX+1), Vtaux_d(NEMAX+1), VtSuav_d(NNOS), PRSuav_d(NNOS))								! Vinculados aos campos m�dios de vari�veis
ALLOCATE(Umed_d(NNOS), Vmed_d(NNOS), Wmed_d(NNOS), PRmed_d(NNOS), VTmed_d(NNOS), PRSmed_d(NNOS))

