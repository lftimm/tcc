!          ---------------    ----------------------------------------
!                            CONDICOES DE NEUMANN
!                           ----------------------

! ***************************************************************************
! Atribui-se  "FF.nnn" aos 6 ultimos caracteres da variavel "PTNAME"
! ***************************************************************************

! cnorm = 0.0D0
! PTNAME(7:14)='FF.nnn  '

! OPEN(2,FILE=PTNAME,STATUS='OLD')

  ! DO I=1,NNMAX
    ! READ (2,*) NNO,cnorm(1,NNOCON),cnorm(2,NNOCON),cnorm(3,NNOCON)
  ! END DO

! CLOSE(2)

! KCONTS = 0
! IELCS = 0
! AREACS = 0.0d0
! CSNOR1 = 0.0d0
! CSNOR2 = 0.0d0
! CSNOR3 = 0.0d0
! IBNOBJ = 0
IF(MNOBJ.NE.0) THEN

  DO NOB=1,MNOBJ

    NB1 = NOB/10 + 48
    NB2 = NOB - (NOB/10)*10 + 48

!         ARQUIVO 'CS##.sup' - AREAS E CONETIVIDADES DAS FACES DE CONTORNO
!        ------------------------------------------------------------------ 
!                                      S�LIDO
!                                     --------
!
!   ***************************************************************************
!   Atribui-se "CS##.sup" aos 8 �ltimos caracteres da variavel "PTNAME"
!   ***************************************************************************

    PTNAME(7:8)='CS'
    PTNAME(9:10)=CHAR(NB1)//CHAR(NB2)
    PTNAME(11:14)='.sup'

    OPEN (2,FILE=PTNAME,STATUS='OLD')

      REWIND (2)
      II=4*NFCSX
      DO I=1,NFCSX
        IF(I.GT.NFCN(NOB)) EXIT
        READ(2,*) IELCS(NOB,I)
        II=4*(I-1)											  !KCONTS AO INV�S DE 4 ERA 8
        READ(2,*) AREACS(NOB,I),KCONTS(NOB,II+1),KCONTS(NOB,II+2),&
                  KCONTS(NOB,II+3),KCONTS(NOB,II+4)			  ! - ALTERADO DEBORAH 26.04.11
      END DO

    CLOSE(2)

!         ARQUIVO 'CS##.nnn' -  VETORES NORMAIS AOS NOS DE CONTORNO S�LIDO      
!        -------------------   --------------------------------------------
!
!   ***************************************************************************
!   Atribui-se  "CS##.nnn" aos 8 �ltimos caracteres da variavel "PTNAME"
!   ***************************************************************************

    PTNAME(11:14)='.nnn'

    OPEN(2,FILE=PTNAME,STATUS='OLD')

      DO I=1,NNCSX
        IF(I.GT.NNCN(NOB)) EXIT
        READ (2,*) IBNOBJ(NOB,I),CSNOR1(NOB,I),CSNOR2(NOB,I),CSNOR3(NOB,I)
      END DO

    CLOSE(2)

   END DO

END IF

! NUMERACAO DOS ARQUIVOS DE ACORDO COM O NUMERO DE REGISTRO CORRENTE 
! ------------------------------------------------------------------

NF1=NFILE/100+48
NF2=(NFILE-(NFILE/100)*100)/10+48
NF3=NFILE-(NFILE/10)*10+48
PTNAME(7:9)=CHAR(NF1)//CHAR(NF2)//CHAR(NF3)

! ****************************************************************************
! Esta e a forma de atribuir as setima e oitava posicoes dos caracteres
! do nome dos arquivos de um determinado registro, exatamente o numero desse
! registro. A dupla barra e a forma sintatica de indicar e separar cada um 
! dos caracteres. ( Ver no "Help" a funcao  CHAR.)     
! ***************************************************************************

!              ARQUIVOS COM OS VALORES NODAIS DAS VARIAVEIS F�SICAS        
!           ----------------------------------------------------------

!                 ARQUIVO '.v': VALORES DE "U" "V" E "W" NOS N�S 
!               --------------------------------------------------
!                 ARQUIVO '.pr': VALORES DE "PR" E PRSuav NOS N�S
!               ---------------------------------------------------
!					ARQUIVO '.t': VALORES DE "T" NOS N�S						!XXXX  
!                  ----------------------------------------
!					ARQUIVO '.rha': VALORES DE "RHA" NOS N�S					!XXXXM  
!                  --------------------------------------------

! ***************************************************************************
! Atribui-se  aos 3 �ltimos caracteres da variavel "PTNAME" a extensao
! equivalente a variavel fisica armazenada em cada arquivo
! ***************************************************************************

PTNAME(10:14)='.v   '

OPEN(2,FILE=PTNAME,STATUS='OLD')
  REWIND (2)
  DO I=1,NNM
    READ(2,*)  uvw(1,I),uvw(2,I),uvw(3,I)
  END DO
CLOSE(2)
!----------------------------------
PTNAME(10:14)='.pr  '

OPEN(3,FILE=PTNAME,STATUS='OLD')
  REWIND (3)
  DO I=1,NNM
    READ(3,*)  uvw(4,I),PRSuav(I)
  END DO
CLOSE(3)

write(*,*) "Passou cond contorno"

! ***************************************************************************
!            ARQUIVOS COM AS CONDICOES DE CONTORNO DAS VARIAVIES FISICAS 
!           -------------------------------------------------------------
!              ARQUIVO 'CC.bv': CONDICOES DE CONTORNO PARA "U" "V" E "W" 
!              ---------------------------------------------------------
!              ARQUIVO 'CC.bp': CONDICOES DE CONTORNO PARA "PR"
!              ------------------------------------------------     
!              ARQUIVO 'CC.bt': CONDICOES DE CONTORNO PARA "T"		 !XXXX
!              -------------------------------------------------
!			   ARQUIVO 'CC.brha': CONDICOES DE CONTORNO PARA "RHA"	 !XXXXM
!			   ---------------------------------------------------- 

! ***************************************************************************
! Atribui-se  aos  ultimos caracteres da variavel "PTNAME" os caracteres
! "CC" e a extensao equivalente a variavel fisica armazenada em cada arquivo
! ***************************************************************************
! ***************************************************************************
! NBCU e a quantidade de nos com condicoes de contorno (neste caso -> U).
! IBCU(I) e o Nro do no global respectivo ao no de contorno corrente "I".
! BCU(I)  e o valor da variavel prescrita (neste caso -> U).
! ***************************************************************************

  PTNAME(7:14) ='CC.bv   '
  OPEN(2,FILE=PTNAME,STATUS='OLD')
  REWIND (2)

	READ(2,*) NBCU
	IF (NBCU.NE.0) THEN
	 DO I=1,NBCU
	   READ(2,*) IBCU(I),BCU(I)
	   END DO
	END IF

	 READ(2,*) NBCV
	IF (NBCV.NE.0) THEN
	  DO I=1,NBCV
	   READ(2,*) IBCV(I),BCV(I)
	 END DO
	 END IF

	 READ(2,*) NBCW
	 IF (NBCW.NE.0) THEN
	  DO I=1,NBCW
	   READ(2,*) IBCW(I),BCW(I)
	 END DO
	 END IF
  CLOSE(2)
!----------------------------------
  PTNAME(7:14) ='CC.bp   '
  OPEN(3,FILE=PTNAME,STATUS='OLD')
  REWIND (3)

	 READ(3,*) NBCP
	 IF (NBCP.NE.0) THEN
	  DO I=1,NBCP
	   READ(3,*) IBCP(I),BCP(I)
	 END DO
	 END IF
  CLOSE(3)

! ----------------------------------------------------------
! CONDICOES DE CONTORNO INICIAIS PARA VELOCIDADE, PRESS�O, 
! TEMPERATURA E MASSA											!XXXX !XXXXM
! ----------------------------------------------------------

IF (NBCU.NE.0) THEN
  DO I= 1,NBCU
    NNO= IBCU(I)
    uvw(1,NNO)= BCU(I)
  END DO
END IF

IF (NBCV.NE.0) THEN
  DO I= 1,NBCV
    NNO= IBCV(I)
    uvw(2,NNO)= BCV(I)
  END DO
END IF

IF (NBCW.NE.0) THEN
  DO I= 1,NBCW
    NNO= IBCW(I)
    uvw(3,NNO)= BCW(I)
  END DO
END IF
!----------------------------
IF (NBCP.NE.0) THEN
  DO I= 1,NBCP
    NNO= IBCP(I)
    uvw(4,NNO)= BCP(I)
  END DO
END IF


if (LCONTCARA ==0) LCONTCARA = 1						!!!! EVITAR PROBLEMAS DE ALOCA��O DE RECURSOS

! -----------------------------------------------------------------
!***** ZERAMENTO DOS VETORES CONTENDO AS VARI�VEIS DE CAMPO M�DIO:
! -----------------------------------------------------------------

IF(NPASS.NE.NNAUX) THEN

  Umed = 0.0D0
  Vmed = 0.0D0
  Wmed = 0.0D0
  PRmed = 0.0D0
  VTmed = 0.0D0
  PRSmed = 0.0D0				

END IF

! ---------------------------------------------------------------------------
! ---------------------------------------------------------------------------
! ------ BLOCO "C" ------ BLOCO "C" ------ BLOCO "C" ------ BLOCO "C" -------
! ---------------------------------------------------------------------------

! MONTAGEM DE NEIBOL E NEIBOR
! *************************** 

! As Matrizes NEIBOR e NEIBOL servem para o processo de montagem dos vetores
! Globais. Esta montagem deve dar-se em forma vetorizada para aumentar a
! eficiencia do programa portanto, por isso utilizam-se estes "Arrays".
!    
! IPOS e um indice para correlacionar as correspondentes posicoes das matrizes 
!     [ Por exemplo NEIBOR(3,NODE) se corresponde com NEIBOL(3,NODE)].
! NODE indica o Numero de No Global.
!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!
!OBS: NEIBOR E NEIBOL ALTERADOS DE 0:16 PARA 0:8 EM 26.12.11 MOTIVO: STACK OVERFLOW  !XXXX3D alterado 26.12.11
!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!
! NEIBOR(IPOS,NODE): *na sua primeira posicao, NEIBOR(0,NODE),contem a
!                     quantidade de elementos concorrentes ao no global
!                     "NODE". SE CONSIDERA QUE NAO PODE HAVER MAIS DE 16 
!                     ELEMENTOS CONCORRENTES AO MESMO NO (Valido apenas  
!                     para malhas estruturadas).
!                    *nas posicoes restantes, [ NEIBOR(1,NODE) a 
!                     NEIBOR(8,NODE) ], contem o numero de elemento. 
!                     IPOS vai de 1 a 8 pois no maximo pode haver 
!                     8 elementos concorrentes a um determinado no. 
!
! NEIBOL(IPOS,NODE): *na sua primeira posicao, NEIBOL(0,NODE),contem a
!                     quantidade de elementos concorrentes ao no global
!                     "NODE".
!                    *nas posicoes restantes, [ NEIBOL(1,NODE) a 
!                     NEIBOL(16,NODE) ], contem o numero local de nodo do
!                     elemento dado pela matriz NEIBOR, correspondente 
!                     ao no global NODE.

! XXXXNEIB - Modificado para poder usar at� 12 elemeentos ao redor de um n�
DO I=1,NNOS
  NEIBOR(0:12,I)=0
  NEIBOL(0:12,I)=0     !XXXXP
  
END DO

DO IP=1,8
  DO I=1,NELEM
    I1 = 8*I - 8 + IP
    NODE = KONE(I1)
    NEIBOR(0,NODE) = NEIBOR(0,NODE) + 1
    NEIBOL(0,NODE) = NEIBOR(0,NODE)          !XXXXP 
    IPOS = NEIBOR(0,NODE)
    NEIBOR(IPOS,NODE) = I
   NEIBOL(IPOS,NODE) = IP                   !XXXXP

  END DO 
END DO 

! *************************************************************************************

! FORMACAO DE MATRIZES ATRAVES DO PRODUTO DAS FUNCOES DE INTERPOLACAO E SUAS DERIVADAS 
! *************************************************************************************
!(j� integrados)
     
do j=1,8

  DO i=1,8   

    MMM(I,J)= (1.D0+ETA(I)*ETA(J)/3.D0)*(1.D0+DZET(I)*DZET(J)/3.D0)*(1.D0+XI(I)*XI(J)/3.D0) 
      
    DIFMA(I,J)= -MMM(I,J)
        
    BB1(I,J)= XI(J)*(1.D0+ETA(I)*ETA(J)/3.D0)*(1.D0+DZET(I)*DZET(J)/3.D0)
    BB2(I,J)= ETA(J)*(1.D0+DZET(I)*DZET(J)/3.D0)*(1.D0+XI(I)*XI(J)/3.D0)
    BB3(I,J)= DZET(J)*(1.D0+XI(I)*XI(J)/3.D0)*(1.D0+ETA(I)*ETA(J)/3.D0)

    TB1(I,J)= XI(I)*(1.D0+ETA(I)*ETA(J)/3.D0)*(1.D0+DZET(I)*DZET(J) /3.D0)
    TB2(I,J)= ETA(I)*(1.D0+DZET(I)*DZET(J)/3.D0)*(1.D0+XI(I)*XI(J)/3.D0)
    TB3(I,J)= DZET(I)*(1.D0+XI(I)*XI(J)/3.D0)*(1.D0+ETA(I)*ETA(J) /3.D0)
       
    EXP3(I,J)= (1.D0+DZET(I)*DZET(J)/3.D0)
    EXP2(I,J)= (1.D0+ETA(I)*ETA(J)/3.D0)
    EXP1(I,J)= (1.D0+XI(I)*XI(J)/3.D0)

    DD11(I,J)= XI(I)*BB1(I,J)
    DD22(I,J)= ETA(I)*BB2(I,J)
    DD33(I,J)= DZET(I)*BB3(I,J)
    DD12(I,J)= XI(I)*ETA(J)*EXP3(I,J)
    DD13(I,J)= XI(I)*DZET(J)*EXP2(I,J)
    DD21(I,J)= XI(J)*ETA(I)*EXP3(I,J)
    DD23(I,J)= ETA(I)*DZET(J)*EXP1(I,J)
    DD31(I,J)= XI(J)*DZET(I)*EXP2(I,J)
    DD32(I,J)= ETA(J)*DZET(I)*EXP1(I,J)
   
  END DO
       
  DIFMA(j,j)= 8.D0 - MMM(j,j)

end do
	 
	 
! CALCULO DA MATRIZ UTILIZADA PARA CONTROLE DE HOURGLASSING (parcial)
! *********************************************************

DO I=1, 8
  DO J=1, 8 
  HOURG(I,J)=SIGMA1(I)*SIGMA1(J)+SIGMA2(I)*SIGMA2(J)+SIGMA3(I)*SIGMA3(J)+SIGMA4(I)*SIGMA4(J)
  END DO
END DO

! ZERAMENTO DOS VETORES E MATRIZES QUE SERAO MONTADOS USANDO AS MATRIZES 
! **********************************************************************
! NEIBOR E NEIBOL, NA POSICAO CORRESPONDENTE AO SUBINDICE ZERO
! ************************************************************

VOLU(0)  =0.0D0

! VOLUMES MAXIMO E MINIMO E DELTA T 
! *********************************

VOLMIN= 1.0D6
VOLMAX= 0.0D0

DO IELEM=1,NELEM

  II= (IELEM-1)*8
       
  do i=1,8
    xyzt(i,1) = xyz(1,kone(ii+i))
    xyzt(i,2) = xyz(2,kone(ii+i))
    xyzt(i,3) = xyz(3,kone(ii+i))
  end do	 
       
! MATRIZ JACOBIANA NO PONTO:(XI=0,ETA=0,DZET=0) 
! -----------------------------------------------

  j11 = dot_product(xi,xyzt(:,1))*0.125d0
  j12 = dot_product(xi,xyzt(:,2))*0.125d0
  j13 = dot_product(xi,xyzt(:,3))*0.125d0

  j21 = dot_product(eta,xyzt(:,1))*0.125d0
  j22 = dot_product(eta,xyzt(:,2))*0.125d0
  j23 = dot_product(eta,xyzt(:,3))*0.125d0

  j31 = dot_product(dzet,xyzt(:,1))*0.125d0
  j32 = dot_product(dzet,xyzt(:,2))*0.125d0
  j33 = dot_product(dzet,xyzt(:,3))*0.125d0


! DETERMINANTE JACOBIANO NO PONTO:(XI=0,ETA=0,DZET=0) 
! ------------------------------------------------------ 

  DETERJ(IELEM)= J11*J22*J33-J11*J23*J32-J21*J12*J33+J21*J13*J32+J31*J12*J23-J31*J13*J22


! INVERSA DA MATRIZ JACOBIANA NO PONTO:(XI=0,ETA=0,DZET=0)
! ----------------------------------------------------------- 

! ***************************************************************************
!  -1                                                           
! J  = JB / DET J ... sendo JB a trasposta da matriz adjunta de J. 
! ~    ~        ~            ~                                  ~
! ***************************************************************************

  JB11= (J22*J33-J23*J32)
  JB12=-(J12*J33-J13*J32)
  JB13= (J12*J23-J13*J22)
  JB21=-(J21*J33-J23*J31)
  JB22= (J11*J33-J13*J31)
  JB23=-(J11*J23-J13*J21)
  JB31= (J21*J32-J22*J31)
  JB32=-(J11*J32-J12*J31)
  JB33= (J11*J22-J12*J21)

  jin(1,IELEM)= JB11/DETERJ(IELEM)
  jin(2,IELEM)= JB12/DETERJ(IELEM)
  jin(3,IELEM)= JB13/DETERJ(IELEM)
  jin(4,IELEM)= JB21/DETERJ(IELEM)
  jin(5,IELEM)= JB22/DETERJ(IELEM)
  jin(6,IELEM)= JB23/DETERJ(IELEM)
  jin(7,IELEM)= JB31/DETERJ(IELEM)
  jin(8,IELEM)= JB32/DETERJ(IELEM)
  jin(9,IELEM)= JB33/DETERJ(IELEM)
  
  !write(*,*) ielem, jin(1, IELEM), jin(2, IELEM), jin(3, IELEM)

! ***************************************************************************
!                           VOLUME DO ELEMENTO
!                          --------------------
!               (Vetor que contem o volume de cada elemento) 
!
! ***************************************************************************

  VOLU(IELEM)= 8.D0*DETERJ(IELEM)

  IF (VOLU(IELEM).GT.VOLMAX) VOLMAX= VOLU(IELEM)
  IF (VOLU(IELEM).LT.VOLMIN) VOLMIN= VOLU(IELEM)

! ***************************************************************************
! Necessita-se dos volumes maximo e minimo para as formulas de controle de
! modos espureos (HOURGLASS)
! ***************************************************************************

  DL12=SQRT((xyzt(2,1)-xyzt(1,1))*(xyzt(2,1)-xyzt(1,1))+(xyzt(2,2)-&
              xyzt(1,2))*(xyzt(2,2)-xyzt(1,2))+(xyzt(2,3)-xyzt(1,3))&
              *(xyzt(2,3)-xyzt(1,3)))
  DL23=SQRT((xyzt(3,1)-xyzt(2,1))*(xyzt(3,1)-xyzt(2,1))+(xyzt(3,2)-&
              xyzt(2,2))*(xyzt(3,2)-xyzt(2,2))+(xyzt(3,3)-xyzt(2,3))&
              *(xyzt(3,3)-xyzt(2,3)))
  DL34=SQRT((xyzt(4,1)-xyzt(3,1))*(xyzt(4,1)-xyzt(3,1))+(xyzt(4,2)-&
              xyzt(3,2))*(xyzt(4,2)-xyzt(3,2))+(xyzt(4,3)-xyzt(3,3))&
              *(xyzt(4,3)-xyzt(3,3)))
  DL41=SQRT((xyzt(1,1)-xyzt(4,1))*(xyzt(1,1)-xyzt(4,1))+(xyzt(1,2)-&
              xyzt(4,2))*(xyzt(1,2)-xyzt(4,2))+(xyzt(1,3)-xyzt(4,3))&
              *(xyzt(1,3)-xyzt(4,3)))
  DL15=SQRT((xyzt(5,1)-xyzt(1,1))*(xyzt(5,1)-xyzt(1,1))+(xyzt(5,2)-&
              xyzt(1,2))*(xyzt(5,2)-xyzt(1,2))+(xyzt(5,3)-xyzt(1,3))&
              *(xyzt(5,3)-xyzt(1,3)))
  DL26=SQRT((xyzt(6,1)-xyzt(2,1))*(xyzt(6,1)-xyzt(2,1))+(xyzt(6,2)-&
              xyzt(2,2))*(xyzt(6,2)-xyzt(2,2))+(xyzt(6,3)-xyzt(2,3))&
              *(xyzt(6,3)-xyzt(2,3)))
  DL37=SQRT((xyzt(7,1)-xyzt(3,1))*(xyzt(7,1)-xyzt(3,1))+(xyzt(7,2)-&
              xyzt(3,2))*(xyzt(7,2)-xyzt(3,2))+(xyzt(7,3)-xyzt(3,3))&
              *(xyzt(7,3)-xyzt(3,3)))
  DL48=SQRT((xyzt(8,1)-xyzt(4,1))*(xyzt(8,1)-xyzt(4,1))+(xyzt(8,2)-&
              xyzt(4,2))*(xyzt(8,2)-xyzt(4,2))+(xyzt(8,3)-xyzt(4,3))&
              *(xyzt(8,3)-xyzt(4,3)))
  DL56=SQRT((xyzt(6,1)-xyzt(5,1))*(xyzt(6,1)-xyzt(5,1))+(xyzt(6,2)-&
              xyzt(5,2))*(xyzt(6,2)-xyzt(5,2))+(xyzt(6,3)-xyzt(5,3))&
              *(xyzt(6,3)-xyzt(5,3)))
  DL67=SQRT((xyzt(7,1)-xyzt(6,1))*(xyzt(7,1)-xyzt(6,1))+(xyzt(7,2)-&
              xyzt(6,2))*(xyzt(7,2)-xyzt(6,2))+(xyzt(7,3)-xyzt(6,3))&
              *(xyzt(7,3)-xyzt(6,3)))
  DL78=SQRT((xyzt(8,1)-xyzt(7,1))*(xyzt(8,1)-xyzt(7,1))+(xyzt(8,2)-&
              xyzt(7,2))*(xyzt(8,2)-xyzt(7,2))+(xyzt(8,3)-xyzt(7,3))&
              *(xyzt(8,3)-xyzt(7,3)))
  DL85=SQRT((xyzt(5,1)-xyzt(8,1))*(xyzt(5,1)-xyzt(8,1))+(xyzt(5,2)-&
              xyzt(8,2))*(xyzt(5,2)-xyzt(8,2))+(xyzt(5,3)-xyzt(8,3))&
              *(xyzt(5,3)-xyzt(8,3)))

  DELTAL = MIN( DL12,DL23,DL34,DL41,DL15,DL26,DL37,DL48,DL56,DL67,DL78,DL85 )

  !write(*,*) "DELTAL", DL12,DL23,DL34,DL41,DL15,DL26,DL37,DL48,DL56,DL67,DL78,DL85 
  !write(*,*) Deltal
  !pause
  
  
! CONDI��O DE ESTABILIDADE PARA ESCOAMENTOS COM CONVEC��O DOMINANTE     
      
  DeltE=CSEGUR*DELTAL/(VelSom+Vinf)
  
  !write(*,*) "DeltE", DeltE, CSEGUR, DELTAL, VelSom, Vinf

! CONDI��O DE ESTABILIDADE PARA ESCOAMENTOS COM DIFUS�O DOMINANTE

  IF (DeltE.LT.DtMAX) DtMAX=DeltE


END DO
 
!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!

IF(IndTurb.EQ.2) THEN							!XXXXT 06.07.11 permanece igual

! ************************
! SELE��O DOS N�S PARA COMPOSI��O DOS FILTROS INDIVIDUAIS DE CADA UM DOS N�S
! **************************************************************************
! EXISTENTES NA MALHA PARA O PROCESSO DE SEGUNDA FILTRAGEM DO MODELO DIN�MICO
! ***************************************************************************
! DE TURBUL�NCIA
! **************

! ***** Zeramento da primeira posi��o de arrays usados	no modelo din�mico:

  NDSUP = 0
  NDDIST = 0.0D0

  DO I=1,NNM

    II=NEIBOR(0,I)
    VOLtot=0.0D0
    JCOUNT=0

!***********************************************************************
!***** Parte do algoritmo referente a n�s com apenas 1 elemento em comum:
!***********************************************************************
!quando n� � de canto do dom�nio				!XXXXT 06.07.11 permanece igual

    IF(II.EQ.1) THEN

      NLM=NEIBOR(1,I)

      VOLtot = VOLtot + VOLU(NLM)

      do j=1,8
	    nd(j) = kone(8*nlm-8+j)
	  end do

!     ***** Tomando o n� diametralmente oposto a I no mesmo plano:

      DO J=1,8

        JJ=ND(J)

        IF(JJ.EQ.I) THEN

          IF(J.LE.2) THEN

            JK=J+2
            JK2=J+4
            JK3=8*(NLM-1)+JK2
            JK4=KONE(JK3)

            JCOUNT=JCOUNT +1
            NDSUP(0,I)=JCOUNT
            NDSUP(JCOUNT,I)=JK4

            Dx = xyz(1,JK4) - xyz(1,I)
            Dy = xyz(2,JK4) - xyz(2,I)
            Dz = xyz(3,JK4) - xyz(3,I)

            NDDIST(JCOUNT,I) = SQRT(Dx*Dx + Dy*Dy + Dz*Dz)

          END IF

          IF((J.GT.2).AND.(J.LE.4)) THEN

            JK=J-2
            JK2=J+4
            JK3=8*(NLM-1)+JK2
            JK4=KONE(JK3)

            JCOUNT=JCOUNT +1
            NDSUP(0,I)=JCOUNT
            NDSUP(JCOUNT,I)=JK4

            Dx = xyz(1,JK4) - xyz(1,I)
            Dy = xyz(2,JK4) - xyz(2,I)
            Dz = xyz(3,JK4) - xyz(3,I)

            NDDIST(JCOUNT,I) = SQRT(Dx*Dx + Dy*Dy +  Dz*Dz)

          END IF

          IF((J.GT.4).AND.(J.LE.6)) THEN

            JK=J+2
            JK2=J-4
            JK3=8*(NLM-1)+JK2
            JK4=KONE(JK3)

            JCOUNT=JCOUNT +1
            NDSUP(0,I)=JCOUNT
            NDSUP(JCOUNT,I)=JK4

            Dx = xyz(1,JK4) - xyz(1,I)
            Dy = xyz(2,JK4) - xyz(2,I)
            Dz = xyz(3,JK4) - xyz(3,I)

            NDDIST(JCOUNT,I) = SQRT(Dx*Dx + Dy*Dy +  Dz*Dz)

          end if

          IF(J.GT.6) THEN

            JK=J-2
            JK2=J-4
            JK3=8*(NLM-1)+JK2
            JK4=KONE(JK3)

            JCOUNT=JCOUNT +1
            NDSUP(0,I)=JCOUNT
            NDSUP(JCOUNT,I)=JK4

            Dx = xyz(1,JK4) - xyz(1,I)
            Dy = xyz(2,JK4) - xyz(2,I)
            Dz = xyz(3,JK4) - xyz(3,I)

            NDDIST(JCOUNT,I) = SQRT(Dx*Dx + Dy*Dy +   Dz*Dz)

          END IF

          NI=8*(NLM-1)+JK
          IN=KONE(NI)

          EXIT
               
        END IF

      END DO

      II=NEIBOR(0,IN)

      DO J=1,II

        NEL=NEIBOR(J,IN)

        IF(NEL.NE.NLM) THEN

          VOLtot = VOLtot + VOLU(NEL)

          DO IJ=1,8

            JI=8*(NEL-1)+IJ
            JJ=KONE(JI)

            IF(JJ.EQ.IN) THEN

              IF(IJ.LE.2) THEN

                JK=IJ+2
                JL1=8*(NEL-1)+JK
                JL2=KONE(JL1)

                JCOUNT=JCOUNT +1
                NDSUP(0,I)=JCOUNT
                NDSUP(JCOUNT,I)=JL2

                Dx = xyz(1,JL2) - xyz(1,I)
                Dy = xyz(2,JL2) - xyz(2,I)
                Dz = xyz(3,JL2) - xyz(3,I)

                NDDIST(JCOUNT,I) = SQRT(Dx*Dx + Dy*Dy + Dz*Dz)

              END IF

              IF((IJ.GT.2).AND.(IJ.LE.4)) THEN

                JK=IJ-2
                JL1=8*(NEL-1)+JK
                JL2=KONE(JL1)

                JCOUNT=JCOUNT +1
                NDSUP(0,I)=JCOUNT
                NDSUP(JCOUNT,I)=JL2

                Dx = xyz(1,JL2) - xyz(1,I)
                Dy = xyz(2,JL2) - xyz(2,I)
                Dz = xyz(3,JL2) - xyz(3,I)

                NDDIST(JCOUNT,I) = SQRT(Dx*Dx + Dy*Dy + Dz*Dz)

              END IF

              IF((IJ.GT.4).AND.(IJ.LE.6)) THEN

                JK=IJ+2
                JL1=8*(NEL-1)+JK
                JL2=KONE(JL1)

                JCOUNT=JCOUNT +1
                NDSUP(0,I)=JCOUNT
                NDSUP(JCOUNT,I)=JL2
 
                Dx = xyz(1,JL2) - xyz(1,I)
                Dy = xyz(2,JL2) - xyz(2,I)
                Dz = xyz(3,JL2) - xyz(3,I)

                NDDIST(JCOUNT,I) = SQRT(Dx*Dx + Dy*Dy + Dz*Dz)

              END IF

              IF(IJ.GT.6) THEN

                JK=IJ-2
                JL1=8*(NEL-1)+JK
                JL2=KONE(JL1)

                JCOUNT=JCOUNT +1
                NDSUP(0,I)=JCOUNT
                NDSUP(JCOUNT,I)=JL2

                Dx = xyz(1,JL2) - xyz(1,I)
                Dy = xyz(2,JL2) - xyz(2,I)
                Dz = xyz(3,JL2) - xyz(3,I)

                NDDIST(JCOUNT,I) = SQRT(Dx*Dx + Dy*Dy +  Dz*Dz)

              END IF
                        
              EXIT

            END IF

          END DO

        END IF

      END DO

	!se n� n�o � no canto do dom�nio			!XXXXT 06.07.11 permanece igual

     ELSE 

       DO J=1,II

         NEL=NEIBOR(J,I)
         VOLtot=Voltot+VOLU(NEL)

         JI=8*(NEL-1)
         N1=KONE(JI+1)
         N2=KONE(JI+2)
         N3=KONE(JI+3)
         N4=KONE(JI+4)
         N5=KONE(JI+5)
         N6=KONE(JI+6)
         N7=KONE(JI+7)
         N8=KONE(JI+8)

         IF(I.EQ.N1) THEN
           JND(1)=N2
           JND(2)=N4
           JND(3)=N5
         END IF

         IF(I.EQ.N2) THEN
           JND(1)=N1
           JND(2)=N3
           JND(3)=N6
         END IF

         IF(I.EQ.N3) THEN
           JND(1)=N2
           JND(2)=N4
           JND(3)=N7
         END IF

         IF(I.EQ.N4) THEN
           JND(1)=N3
           JND(2)=N1
           JND(3)=N8
         END IF

         IF(I.EQ.N5) THEN
           JND(1)=N6
           JND(2)=N8
           JND(3)=N1
         END IF

         IF(I.EQ.N6) THEN
           JND(1)=N5
           JND(2)=N7
           JND(3)=N2
         END IF

         IF(I.EQ.N7) THEN
           JND(1)=N6
           JND(2)=N8
           JND(3)=N3
         END IF

         IF(I.EQ.N8) THEN
           JND(1)=N7
           JND(2)=N5
           JND(3)=N4
         END IF

         IF(J.EQ.1) THEN

           DO IJ=1,3

             JJ=JND(IJ)
             JCOUNT=JCOUNT+1
             NDSUP(0,I)=JCOUNT
             NDSUP(JCOUNT,I)=JJ

             Dx = xyz(1,JJ) - xyz(1,I)
             Dy = xyz(2,JJ) - xyz(2,I)
             Dz = xyz(3,JJ) - xyz(3,I)

             NDDIST(JCOUNT,I) = SQRT(Dx*Dx + Dy*Dy +  Dz*Dz)

           END DO

         ELSE

           DO IJ=1,3

             JPAR=0
             JJ=JND(IJ)

             DO IK=1,JCOUNT

               JK=NDSUP(IK,I)

               IF(JJ.EQ.JK) THEN
                 JPAR=1
                 EXIT
               end if

             end do

            IF(JPAR.EQ.0) THEN

              JCOUNT=JCOUNT+1
              NDSUP(0,I)=JCOUNT
              NDSUP(JCOUNT,I)=JJ

              Dx = xyz(1,JJ) - xyz(1,I)
              Dy = xyz(2,JJ) - xyz(2,I)
              Dz = xyz(3,JJ) - xyz(3,I)

              NDDIST(JCOUNT,I) = SQRT(Dx*Dx + Dy*Dy +  Dz*Dz)

            end if

          end do

        end if

      end do

    end if

    FILTR2(I)=(VOLtot)**(1.0D0/3.0D0)

  end do

end if

!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!
                                                              
! CALCULO DO INTERVALO DE TEMPO QUE SERA ADOTADO 
! **********************************************         
      
Delt=DtMAX

! CALCULO DO TEMPO TOTAL

TFt= TPOAC+NIR*(NTR-NFILE)*Delt

! ***************************************************************************
! O Tempo total e igual a NIR*NTR*Delt; se todavia nao tem-se gravado 
! nenhum registro, NFILE = TPOAC = 0 e assim obtem-se o mesmo. Porem, se 
! inicia-se a simulacao a partir de um certo registro previamente obtido, 
! TPOAC contem o tempo ("variavel fisica") alcancado na rodada anterior. 
! ***************************************************************************

TEMPO= TPOAC

! *****************************************************************************
! VNVX: Relacao entre o menor e o maior volume usado na formula de Hourglassing. 
! *****************************************************************************

VNVX=VOLMIN/VOLMAX	    
 
! MONTAGEM DO VETOR QUE CONTEM OS ELEMENTOS DA DIAGONAL PRINCIPAL DA MATRIZ
! *************************************************************************
! DE MASSA CONCENTRADA 
! ******************** 
!(n�o precisaria mais pois ArAux (�rea de influencia da for�a) n�o depende
! mais de MLUM, isso foi modificado em 18.05.11 e a �rea de influencia passou
! a ser somente o somat�rio de 0,25 das �reas adjacentes ao n�)  

mlum = 0.0d0
do i=1,nelem
  do j=i*8-7,i*8
    mlum(kone(j)) = mlum(kone(j))+volu(i)
  end do
end do
mlum=mlum*.125d0

!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!
IF(MNOBJ.NE.0) THEN

! *******************************************************************************
! Suaviza��o das �reas de contorno s�lido utilizadas no c�lculo dos 
! coeficientes aerodin�micos:
! *******************************************************************************
  DO NOB=1,MNOBJ

    ArAux=0.0D0

    DO I=1,NFCSX

      IF(I.GT.NFCN(NOB)) EXIT
      IELM=IELCS(NOB,I)
      ArAux(IELM)=(AREACS(NOB,I)*0.25D0)				

    END DO

    DO J=1,NNCSX

      IF(J.GT.NNCN(NOB)) EXIT

      I=IBNOBJ(NOB,J)

	! XXXXNEIB - Modificado para poder usar at� 12 elemeentos ao redor de um n�
      K10 = NEIBOR(1,I)
      K20 = NEIBOR(2,I)
      K30 = NEIBOR(3,I)
      K40 = NEIBOR(4,I)
      K50 = NEIBOR(5,I)
      K60 = NEIBOR(6,I)
      K70 = NEIBOR(7,I)
      K80 = NEIBOR(8,I)
	  K90 = NEIBOR(9,I)
	  K100 = NEIBOR(10,I)
	  K110 = NEIBOR(11,I)
	  K120 = NEIBOR(12,I)
   
      ARSuav(NOB,J)=  ArAux(K10)+ArAux(K20)+ArAux(K30)+ArAux(K40)+& 
                      ArAux(K50)+ArAux(K60)+ArAux(K70)+ArAux(K80)+&
					  ArAux(K90)+ArAux(K100)+ArAux(K110)+ArAux(K120)!/mlum(I)     

    END DO

  END DO

end if
!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!
  
! ABERTURA DOS ARQUIVOS DE RESIDUO E ARMAZENAGEM DOS COEFICIENTES AERODIN�MICOS
! *****************************************************************************

IF(MNOBJ.NE.0) THEN

  NOPF=29

  DO NOB=1,MNOBJ

    NB1 = NOB/10 + 48
    NB2 = NOB - (NOB/10)*10 + 48

    NOPF=NOPF+1
    PTNAME(7:9)='.fx'
    PTNAME(10:11)=CHAR(NB1)//CHAR(NB2)
    PTNAME(12:14)='   '
    OPEN(NOPF,FILE=PTNAME,STATUS='UNKNOWN')
    REWIND(NOPF)

    NOPF=NOPF+1
    PTNAME(7:9)='.fy'
    PTNAME(10:11)=CHAR(NB1)//CHAR(NB2)
    PTNAME(12:14)='   '
    OPEN(NOPF,FILE=PTNAME,STATUS='UNKNOWN')
    REWIND(NOPF)

    NOPF=NOPF+1
    PTNAME(7:9)='.fz'
    PTNAME(10:11)=CHAR(NB1)//CHAR(NB2)
    PTNAME(12:14)='   '
    OPEN(NOPF,FILE=PTNAME,STATUS='UNKNOWN')
    REWIND(NOPF)

    NOPF=NOPF+1
    PTNAME(7:9)='.mx'
    PTNAME(10:11)=CHAR(NB1)//CHAR(NB2)
    PTNAME(12:14)='  '
    OPEN(NOPF,FILE=PTNAME,STATUS='UNKNOWN')
    REWIND(NOPF)

    NOPF=NOPF+1
    PTNAME(7:9)='.my'
    PTNAME(10:11)=CHAR(NB1)//CHAR(NB2)
    PTNAME(12:14)='  '
    OPEN(NOPF,FILE=PTNAME,STATUS='UNKNOWN')
    REWIND(NOPF)

    NOPF=NOPF+1
    PTNAME(7:9)='.mz'
    PTNAME(10:11)=CHAR(NB1)//CHAR(NB2)
    PTNAME(12:14)='  '
    OPEN(NOPF,FILE=PTNAME,STATUS='UNKNOWN')
    REWIND(NOPF)

    NOPF=NOPF+1
    PTNAME(7:9)='.cp'
    PTNAME(10:11)=CHAR(NB1)//CHAR(NB2)
    PTNAME(12:14)='   '
    OPEN(NOPF,FILE=PTNAME,STATUS='UNKNOWN')
    REWIND(NOPF)

	end do

end if			   

OPEN(14,FILE='residuo.dat',STATUS='UNKNOWN')
REWIND(14)

!*****************************************************************************
!    INICIALIZA��ES  -	 TRECHO DE IN�CIO DOS C�LCULOS MASSIVOS
!*****************************************************************************

INDTPO= 0
NNR= 0
NNNRRR= 0
NCOUNTCOEF=0
VDTurb=0.0D0
SDETP=0.0D0
												    
!Inicializa��o vari�veis para c�lculo componente m�dia e rms-m�dia
         
 Umed_d = 0.0d0
 Vmed_d = 0.0d0
 Wmed_d = 0.0d0
 PRmed_d = 0.0d0
 VTmed_d = 0.0d0
 PRSmed_d = 0.0d0
 
! ****************************************************
! ****************************************************
! Inicio do ciclo de tempo - M�todo de TG
! ****************************************************
! ****************************************************  

!  ---------------------------------------------------------------
!    Blocos de processamento a serem lan�ados
!  ---------------------------------------------------------------
!   Block = max(NEMAX, NNOS)
!  ---------------------------------------------------------------
!    Par�metros necess�rios para uso no kernel - Invariantes no tempo
!  ---------------------------------------------------------------
  
  ! Vetores e Matrizes
  
  write(*,*) 'Transferencia de dados H/D - INICIADA'
 
  !La�o 1 
  kone_d = kone; uvw_d(1:4,:) = uvw(1:4,:); VOLU_d(:) = VOLU(1:NEMAX); JIN_d = JIN
	! Inicializa��o de par�metros
		pp_d = 0.0d0
		
  !La�o 3 a 9
  ndsup_d(1:12,:) = ndsup(1:12,:); NDDIST_d = NDDIST; filtr2_d = filtr2; 
	! Inicializa��o de par�metros
		SmodE_d = 0.0d0; FILTR1_d = 0.0d0; 
		Pij1_d = 0.0d0; Pij2_d = 0.0d0; Pij3_d = 0.0d0; Pij4_d = 0.0d0; Pij5_d= 0.0d0; Pij6_d = 0.0d0;
		Psij_d = 0.0d0; Pfij_d = 0.0d0; uvwf_d = 0.0d0; Sfij_d = 0.0d0;  
		Cxt_d = 0.0d0;  VDTurb_d = 0.0d0;
   
  !La�o 10
  TB1_d = TB1; TB2_d = TB2; TB3_d = TB3; BB1_d = BB1; BB2_d = BB2; BB3_d = BB3; 
  dd11_d = dd11;   dd12_d = dd12; dd13_d = dd13; dd21_d = dd21; dd22_d = dd22; 
  dd23_d = dd23; dd31_d = dd31; dd32_d = dd32; dd33_d = dd33; mlum_d = mlum;
  hourg_d = hourg; mmm_d = mmm; VDTurb_d = VDTurb; DETERJ_d = DETERJ 

	! Inicializa��o de par�metros
		rru_d = 0.0d0; rrv_d = 0.0d0; rrw_d = 0.0d0; rrp_d = 0.0d0
   
   !La�o 11	------ PODEM TER TAMANHO NULO
   !NNEqMom_d = NNEqMom; NNEqTem_d = NNEqTem; 
   FF1f_d = 0.0d0; FF2f_d = 0.0d0; FF3f_d = 0.0d0  
   !IEL_d = IEL;	AREAC_d = AREAC; FCONTOR_d = FCONTOR; CNORM_d = CNORM    
   
   ! La�o 12 e 13
   mlum_d = mlum;
   
   write(*,*) 'Transferencia de dados H/D - INICIADA 2'
   
   
   ! AJUSTES EM NEIBOR E NEIBOL P/ EVITAR PROBLEMA DE MEM�RIA NA GPU 
! *************************************************************************************

! XXXXNEIB - Modificado para poder usar at� 12 elemeentos ao redor de um n�
	NEIBORc(0:12,:) = NEIBOR(0:12,:); NEIBOLc(0:12,:) = NEIBOL(0:12,:) 

	DO I=1,NNOS							! ESTRUTURA C/ MODIFICA��O
 		 DO J=1,12
  			IF ( NEIBORc(J,I) == 0) THEN
				NEIBORc(J,I)=NEMAX+1
  			END IF
			IF ( NEIBOLc(J,I) == 0) THEN
				NEIBOLc(J,I)=9
  			END IF
  		END DO
	END DO

write(*,*) 'Passou por NEIBORc'
   
   
   ! XXXXNEIB - Modificado para poder usar at� 12 elemeentos ao redor de um n�
   K10_d(:) = NEIBORc(1,:); K20_d(:) = NEIBORc(2,:); K30_d(:) = NEIBORc(3,:); K40_d(:) = NEIBORc(4,:)
   K50_d(:) = NEIBORc(5,:); K60_d(:) = NEIBORc(6,:); K70_d(:) = NEIBORc(7,:); K80_d(:) = NEIBORc(8,:)
   K90_d(:) = NEIBORc(9,:); K100_d(:) = NEIBORC(10,:); K110_d(:) = NEIBORc(11,:); K120_d(:) = NEIBORc(12,:)
   L1_d(:) = NEIBOLc(1,:); L2_d(:) = NEIBOLc(2,:); L3_d(:) = NEIBOLc(3,:); L4_d(:) = NEIBOLc(4,:)
   L5_d(:) = NEIBOLc(5,:); L6_d(:) = NEIBOLc(6,:); L7_d(:) = NEIBOLc(7,:); L8_d(:) = NEIBOLc(8,:)
   L9_d(:) = NEIBOLc(9,:); L10_d(:) = NEIBOLc(10,:); L11_d(:) = NEIBOLc(11,:); L12_d(:) = NEIBOLc(12,:)
   
   !K10_d(:) = NEIBOR(1,:); K20_d(:) = NEIBOR(2,:); K30_d(:) = NEIBOR(3,:); K40_d(:) = NEIBOR(4,:)
   !K50_d(:) = NEIBOR(5,:); K60_d(:) = NEIBOR(6,:); K70_d(:) = NEIBOR(7,:); K80_d(:) = NEIBOR(8,:)
   !L1_d(:) = NEIBOL(1,:); L2_d(:) = NEIBOL(2,:); L3_d(:) = NEIBOL(3,:); L4_d(:) = NEIBOL(4,:)
   !L5_d(:) = NEIBOL(5,:); L6_d(:) = NEIBOL(6,:); L7_d(:) = NEIBOL(7,:); L8_d(:) = NEIBOL(8,:)
   
	! Inicializa��o de par�metros 
		rrg_d = 0.0d0; uvwa_d = 0.0d0

  ! La�o 14
  cru_d(:,:) = 0.0D0;    
  crv_d(:,:) = 0.0D0;  
  crw_d(:,:) = 0.0D0; 
   
  ! La�o 15 
  crug_d(:) = 0.0D0  
  crvg_d(:) = 0.0D0 
  crwg_d(:) = 0.0D0
  
  ! La�o 17
  
  if (NBU .NE. 0) then
		IBCU_d = IBCU	
		 BCU_d = BCU
  else
		IBCU_d = 0	
		 BCU_d = 0
  end if
  
  if (NBV .NE. 0) then
		IBCV_d = IBCV	
		 BCV_d = BCV
  else
		IBCV_d = 0	
		 BCV_d = 0
  end if
  
  if (NBW .NE. 0) then
		IBCW_d = IBCW	
		 BCW_d = BCW
  else
		IBCW_d = 0	
		 BCW_d = 0
  end if
  
  if (NBP .NE. 0) then
		IBCP_d = IBCP
		BCP_d  = BCP
  else
		IBCP_d = 0
		BCP_d = 0
  end if
  
  ! La�o 24
  PPROME_d = 0.0d0; Vtaux_d = 0.0d0
  
  ! La�o 25
  !PRSuav_d = 0.0d0; VtSuav_d = 0.0d0
  
  ! La�o 26
   Umed_d = 0.0d0; Vmed_d = 0.0d0; Wmed_d = 0.0d0; PRmed_d = 0.0d0; VTmed_d = 0.0d0; PRSmed_d = 0.0d0
  
  ! Escalares   
  IndTurb_d = IndTurb; VNVX_d = VNVX; elump1_d = elump1; elump2_d = elump2; elump3_d = elump3
  RHOInf_d = RHOInf; ViscCin_d = ViscCin; ViscVol_d = ViscVol; Cv_d = Cv; CONTROL1_d = CONTROL1
  Delt_d = Delt; Dab_d = Dab; Prtlt_d = Prtlt; Kdif_d = Kdif; VelSom_d = VelSom; PASSMED_d = PASSMED 
  
  write(*,*) 'Transferencia de dados H/D - FINALIZADA'
  
DO WHILE ((TEMPO.LT.TFt).AND.(INDTPO.LE.NROTPO))
  
  !!!!!! VER A POSSIBILIDADE DE RETIRAR A IMPRESS�O DE RESULTADOS PARCIAIS DO PROGRAMA DESTA PARTE
  
  TEMPO= TEMPO+Delt
  NNR= NNR+1
  NNNRRR= NNNRRR+1
  NCOUNTCOEF=NCOUNTCOEF+1
    
  write(*,910) NNNRRR,TEMPO,SDETP, CD, CL	
  
! Retencao da pressao, temperatura e concentra��es iniciais 
! para o calculo do residuo:									

  Pri = uvw_d(4,:)
  
  ! Lan�amento do kernel	- Par�metros de entrada e de sa�da do c�digo do "Device"
  
 call laco_1<<<ceiling(real(NEMAX)/tBlock), tBlock>>>(pp_d, uvwprom_d, PNV_d, Gr1P_d, Gr2P_d, Gr3P_d,&
													  VOLU_d, JIN_d, uvw_d, kone_d)
													  													  
!istat = cudaDeviceSynchronize()																											  

  ! Lan�amento do modelo Din�mico
	if (INDTURB .eq. 2) then 

		call dynamic_1<<<ceiling(real(NEMAX)/tBlock), tBlock>>>(pp_d, VOLU_d, Pij1_d, Pij2_d, Pij3_d, Pij4_d, &
													  Pij5_d, Pij6_d, SmodE_d, FILTR1_d)

		call dynamic_2<<<ceiling(real(NNOS)/tBlock), tBlock>>>(Psij_d, mlum_d, K10_d, K20_d, K30_d, K40_d, &
						K50_d, K60_d, K70_d, K80_d, K90_d, K100_d, K110_d, K120_d, Pij1_d, Pij2_d, Pij3_d, Pij4_d, Pij5_d, Pij6_d)

		call dynamic_3<<<ceiling(real(NNOS)/tBlock), tBlock>>>(ndsup_d, Psij_d, NDDist_d, uvw_d, uvwf_d, Pfij_d)

		call dynamic_4<<<ceiling(real(NEMAX)/tBlock), tBlock>>>(VOLU_d, KONE_d, JIN_d, uvwf_d, Pij1_d, &
						Pij2_d, Pij3_d, Pij4_d, Pij5_d, Pij6_d)

		call dynamic_5<<<ceiling(real(NNOS)/tBlock), tBlock>>>(mlum_d, K10_d, K20_d, K30_d, K40_d, K50_d, &
						K60_d, K70_d, K80_d, K90_d, K100_d, K110_d, K120_d, Pij1_d, Pij2_d, Pij3_d, Pij4_d, Pij5_d, Pij6_d, Sfij_d)						

		call dynamic_6<<<ceiling(real(NNOS)/tBlock), tBlock>>>(uvw_d, ndsup_d, NDDIST_d, uvwf_d, Sfij_d, &
						Psij_d, Filtr2_d, Cxt_d)
						
		call dynamic_7<<<ceiling(real(NEMAX)/tBlock), tBlock>>>(VDTurb_d, Cxt_d, FILTR1_d, SmodE_d, kone_d)
 
	end if
 ! Fim do modelo Din�mico
 
 call laco_10<<<ceiling(real(NEMAX)/tBlock), tBlock>>>(kone_d, uvw_d, VOLU_d, mmm_d, elump1_d, elump2_d, &
													   elump3_d, RHOInf_d, ViscCin_d, ViscVol_d, VelSom_d, &
													   Cv_d, CONTROL1_d, Delt_d, Dab_d, Prtlt_d, Kdif_d, &
													   VNVX_d, JIN_d, DETERJ_d, uvwprom_d, TB1_d, TB2_d, &
													   TB3_d, BB1_d, BB2_d, BB3_d, dd11_d, dd12_d, &
													   dd13_d, dd21_d, dd22_d, dd23_d, dd31_d, dd32_d, &
													   dd33_d, hourg_d, rru_d, rrv_d, rrw_d, rrp_d, IndTurb_d, &
													   VDTurb_d)
													   
!istat = cudaDeviceSynchronize()	

!call laco_11<<<ceiling(real(LCONTCARA)/tBlock), tBlock>>>(KONE_d, IEL_d, uvw_d, cnorm_d, uvwprom_d, pp_d, ff1f_d, ff2f_d, &
!														   ff3f_d, AREAC_d, FCONTOR_d, VDTurb_d, Delt_d, ViscCin_d, ViscVol_d, &
!			  											   RHOInf_d, NNEqMom_d)

call laco_12<<<ceiling(real(NNOS)/tBlock), tBlock>>>(K10_d, K20_d, K30_d, K40_d, K50_d, K60_d, &
						K70_d, K80_d, K90_d, K100_d, K110_d, K120_d, L1_d,  L2_d, L3_d, L4_d, L5_d, L6_d, L7_d, L8_d, L9_d, L10_d, L11_d, L12_d, uvw_d, &
						UVWa_d, rru_d, rrv_d, rrw_d, rrp_d, mlum_d, rrg_d)!, ff1f_d, ff2f_d, ff3f_d)	

!istat = cudaDeviceSynchronize()						
						
call laco_14<<<ceiling(real(NEMAX)/tBlock), tBlock>>>(JIN_d, DETERJ_d, kone_d, uvw_d, uvwa_d, BB1_d, BB2_d, &
						BB3_d, cru_d, crv_d, crw_d)				

call laco_15<<<ceiling(real(NNOS)/tBlock), tBlock>>>(crug_d, crvg_d, crwg_d, cru_d, crv_d, crw_d, UVWa_d, &
						mlum_d, RHOInf_d, Delt_d, K10_d, K20_d, K30_d, K40_d, K50_d, K60_d, K70_d, K80_d, K90_d, K100_d, K110_d, K120_d, &
						L1_d,  L2_d, L3_d, L4_d, L5_d, L6_d, L7_d, L8_d, L9_d, L10_d, L11_d, L12_d)	

!istat = cudaDeviceSynchronize()		

call impose_CC<<<ceiling(real(NNOS)/tBlock), tBlock>>>(uvwa_d, IBCU_d, BCU_d, IBCV_d, BCV_d, IBCW_d, BCW_d, &
													 IBCP_d, BCP_d)		
										
istat = cudaDeviceSynchronize()	

! In�cio do Passo 2
										
call laco_18<<<ceiling(real(NEMAX)/tBlock), tBlock>>>(pp_d, uvwprom_d, PNV_d, &
										Gr1P_d, Gr2P_d, Gr3P_d, VOLU_d, JIN_d, uvwa_d, &
										kone_d)									

!istat = cudaDeviceSynchronize()										
										
call laco_19<<<ceiling(real(NEMAX)/tBlock), tBlock>>>(kone_d, uvwa_d, uvw_d, mmm_d, JIN_d, &
						uvwprom_d, TB1_d, TB2_d, TB3_d, BB1_d, BB2_d, BB3_d, dd11_d, dd12_d,&
						dd13_d, dd21_d, dd22_d, dd23_d, dd31_d, dd32_d, dd33_d, hourg_d, &
						rru_d, rrv_d, rrw_d, rrp_d, VOLU_d,  DETERJ_d, Delt_d, RHOinf_d, &
						VNVX_d, CONTROL1_d, Cv_d, ViscVol_d, ViscCin_d, Schit_d, Prtlt_d, &
						Kdif_d, Dab_d, VelSom_d, elump1_d, elump2_d, elump3_d, IndTurb_d, &
						VDTurb_d)	

!istat = cudaDeviceSynchronize()							
						
!call laco_20<<<ceiling(real(LCONTCARA)/tBlock), tBlock>>>(KONE_d, IEL_d, uvwa_d, cnorm_d, pp_d, &
!					   ff1f_d, ff2f_d, ff3f_d, AREAC_d, FCONTOR_d, VDTurb_d, Delt_d, ViscCin_d, &
!					   ViscVol_d, RHOInf_d, NNeqMom_d)	

call laco_21<<<ceiling(real(NNOS)/tBlock), tBlock>>>(mlum_d, K10_d, K20_d, K30_d, K40_d, K50_d, K60_d, &
						K70_d, K80_d, K90_d, K100_d, K110_d, K120_d, L1_d,  L2_d, L3_d, L4_d, L5_d, L6_d, L7_d, L8_d, L9_d, L10_d, L11_d, L12_d, uvw_d, rrg_d, &
						rru_d, rrv_d, rrw_d, rrp_d)		

!istat = cudaDeviceSynchronize()							
						
call Impose_CC_2<<<ceiling(real(NNOS)/tBlock), tBlock>>>(uvw_d, IBCU_d, BCU_d, IBCV_d, BCV_d, IBCW_d, BCW_d, &
													 IBCP_d, BCP_d)						
						
!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!
!!!!!!!!!!!!!!!!!!!!!						FINAL DE DOIS PASSOS								!!!!!!!!!!!!!!!!!!						
!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!
						
istat = cudaDeviceSynchronize()				

Prf = uvw_d(4,:)

!write(*,*) 'Pressao - 20519', PRf(20519)


call laco_24<<<ceiling(real(NEMAX)/tBlock), tBlock>>>(kone_d, uvw_d, VOLU_d, PPROME_d, Vtaux_d, VDTurb_d)

call laco_25<<<ceiling(real(NNOS)/tBlock), tBlock>>>(PPROME_d, Vtaux_d, mlum_d, PRSuav_d, VtSuav_d, &
							K10_d, K20_d, K30_d, K40_d, K50_d, K60_d, K70_d, K80_d, K90_d, K100_d, K110_d, K120_d)
							
istat = cudaDeviceSynchronize()				
						 
! CALCULO DOS CAMPOS MEDIOS DE VELOCIDADE, PRESSAO E VISCOSIDADE PARA UM 
! **********************************************************************
! DETERMINADO PERIODO DE TEMPO (PASSMED)
! **************************************         

  IF(NPASS.NE.NNAUX.and.NNNRRR.GT.NPASS) THEN
  
 !La�o 26  
 call laco_26<<<ceiling(real(NNOS)/tBlock), tBlock>>>(uvw_d, PASSMED_d, VtSuav_d, PRSuav_d, Umed_d, &
										Vmed_d, Wmed_d, PRmed_d, VTmed_d, PRSmed_d)	
  istat = cudaDeviceSynchronize()	
  
  END IF

! ************************************
! CONDICAO PARA GRAVACAO DE RESULTADOS
! ************************************

  IF(NNR.EQ.NIR) THEN

!   ***************************************************************************
!   NNR e um contador dentro do laco de tempo que armazena a quantidade de
!   vezes que entrou-se neste ciclo e NIR e a quantidade de passos de tempo
!   entre registros. Logo se NNR nao e igual a NIR, nao se efetua nenhuma
!   gravacao. Se for igual, e feita a gravacao, soma-se um a NFILE, e zera-se 
!   NNR, para o proximo registro.        
!   ***************************************************************************

!   GRAVACAO DE RESULTADOS
!   **********************

    NFILE=NFILE+1
    NNR=0
    TPOAC=TEMPO

    NF1=NFILE/100+48
    NF2=(NFILE-(NFILE/100)*100)/10+48
    NF3=NFILE-(NFILE/10)*10+48
    PTNAME(7:9)=CHAR(NF1)//CHAR(NF2)//CHAR(NF3)

!   ARQUIVO '.v': VALORES DE "U" "V" E "W" NOS NOS 
!   --------------------------------------------------
!   ARQUIVO '.pr': VALORES DE "PR" E "PRSuav" NOS NOS
!   --------------------------------------------------
!   ARQUIVO '.vts': VALORES DE "VtSuav" NOS NOS
!   -----------------------------------------------

	uvw = uvw_d; PRSuav = PRSuav_d; VtSuav = VtSuav_d

    PTNAME(10:14)='.v   '
    OPEN(2,FILE=PTNAME,STATUS='UNKNOWN')
    REWIND (2)

    PTNAME(10:14)='.pr  '
    OPEN(3,FILE=PTNAME,STATUS='UNKNOWN')
    REWIND (3)

    PTNAME(10:14)='.vts '
    OPEN(4,FILE=PTNAME,STATUS='UNKNOWN')
    REWIND (4)

    DO I=1,NNM
      WRITE(2,*) uvw(1,I),uvw(2,I),uvw(3,I)
      WRITE(3,*) uvw(4,I),PRSuav(I)
	  WRITE(4,*) VtSuav(I)
    END DO

    CLOSE(2)
    CLOSE(3)
    CLOSE(4)

  end if
  
! ***********************************************************************
! FIM DA CONDICAO PARA CALCULO DE COEFICENTES E GRAVACAO DE RESULTADOS
! ***********************************************************************

	IF(NCOUNTCOEF.EQ.NCOEF) THEN
	
		uvw = uvw_d;
		!VDTurb = VDTurb_d

		NCOUNTCOEF=0
		
		!call laco_27<<<ceiling(real(NBJ)/tBlock), tBlock>>>(uvw_d, PASSMED_d, VtSuav_d, PRSuav_d, Umed_d, &
		!								Vmed_d, Wmed_d, PRmed_d, VTmed_d, PRSmed_d)	
		!istat = cudaDeviceSynchronize()
	
	      NARQ=29

      DO NOB = 1,MNOBJ

!       ****************************************
!       CALCULO DE COEFICIENTES AERODINAMICOS
!       ****************************************

        Fx = 0.0D0
        Fy = 0.0D0
        Fz = 0.0D0
        Mx = 0.0D0
        My = 0.0D0
        Mz = 0.0D0

!       *******************************************************************************
!       Procedimentos referentes � obten��o dos valores nodais das componentes
!       do tensor de tens�es viscosas para elementos de fluido em contato com
!       contornos s�lidos. Suaviza��o	do centro para os n�s pertencentes � face
!       de contorno correspondente.
!       *******************************************************************************

!       C�lculo das tens�es nos elementos de contorno s�lido: 

        DO J=1,NFCSX

          IF(J.GT.NFCN(NOB)) EXIT

          IELEM=IELCS(NOB,J)
  
          JINV11= JIN(1,IELEM)
          JINV12= JIN(2,IELEM)
          JINV13= JIN(3,IELEM)
          JINV21= JIN(4,IELEM)
          JINV22= JIN(5,IELEM)
          JINV23= JIN(6,IELEM)
          JINV31= JIN(7,IELEM)
          JINV32= JIN(8,IELEM)
          JINV33= JIN(9,IELEM)

          II= (IELEM-1)*8
        
          N1= KONE(II+1)
          N2= KONE(II+2)
          N3= KONE(II+3)
          N4= KONE(II+4)
          N5= KONE(II+5)
          N6= KONE(II+6)
          N7= KONE(II+7)
          N8= KONE(II+8)

!         ***************************************************************************
!   	  Somatorio dos produtos dos elementos da inversa da matriz jacobiana 
!         pelas coordenadas naturais; para serem usados em produtos formados abaixo. 
!         ***************************************************************************
      
          JCN11 = -JINV11-JINV12-JINV13
          JCN12 =  JINV11-JINV12-JINV13 
          JCN13 =  JINV11+JINV12-JINV13 
          JCN14 = -JINV11+JINV12-JINV13
          JCN15 = -JINV11-JINV12+JINV13
          JCN16 =  JINV11-JINV12+JINV13 
          JCN17 =  JINV11+JINV12+JINV13 
          JCN18 = -JINV11+JINV12+JINV13
     
          JCN21 = -JINV21-JINV22-JINV23
          JCN22 =  JINV21-JINV22-JINV23 
          JCN23 =  JINV21+JINV22-JINV23 
          JCN24 = -JINV21+JINV22-JINV23
          JCN25 = -JINV21-JINV22+JINV23
          JCN26 =  JINV21-JINV22+JINV23 
          JCN27 =  JINV21+JINV22+JINV23 
          JCN28 = -JINV21+JINV22+JINV23
     
          JCN31 = -JINV31-JINV32-JINV33 
          JCN32 =  JINV31-JINV32-JINV33
          JCN33 =  JINV31+JINV32-JINV33          
          JCN34 = -JINV31+JINV32-JINV33
          JCN35 = -JINV31-JINV32+JINV33
          JCN36 =  JINV31-JINV32+JINV33
          JCN37 =  JINV31+JINV32+JINV33
          JCN38 = -JINV31+JINV32+JINV33

!         **************************************************************************
!	      Media dos valores nodais dos produtos das coord naturais pela
!         inversa de J(0) e pelas componentes de velocidade.
!         **************************************************************************
      
          pp(1,IELEM)=(JCN11*uvw(1,n1) + JCN12*uvw(1,n2) + JCN13*uvw(1,n3) +&
                       JCN14*uvw(1,n4)+  JCN15*uvw(1,n5) + JCN16*uvw(1,n6) +&
                       JCN17*uvw(1,n7) + JCN18*uvw(1,n8))*0.125D0
     
          pp(4,IELEM)=(JCN21*uvw(1,n1) + JCN22*uvw(1,n2) + JCN23*uvw(1,n3) +&
                       JCN24*uvw(1,n4)+  JCN25*uvw(1,n5) + JCN26*uvw(1,n6) +&
                       JCN27*uvw(1,n7) + JCN28*uvw(1,n8))*0.125D0
     
          pp(7,IELEM)=(JCN31*uvw(1,n1) + JCN32*uvw(1,n2) + JCN33*uvw(1,n3) +&
                       JCN34*uvw(1,n4)+  JCN35*uvw(1,n5) + JCN36*uvw(1,n6) +&
                       JCN37*uvw(1,n7) + JCN38*uvw(1,n8))*0.125D0


          pp(2,IELEM)=(JCN11*uvw(2,n1) + JCN12*uvw(2,n2) + JCN13*uvw(2,n3) +&
                       JCN14*uvw(2,n4) + JCN15*uvw(2,n5) + JCN16*uvw(2,n6) +&
                       JCN17*uvw(2,n7) + JCN18*uvw(2,n8))*0.125D0
     
          pp(5,IELEM)=(JCN21*uvw(2,n1) + JCN22*uvw(2,n2) + JCN23*uvw(2,n3) +&
                       JCN24*uvw(2,n4) + JCN25*uvw(2,n5) + JCN26*uvw(2,n6) +&
                       JCN27*uvw(2,n7) + JCN28*uvw(2,n8))*0.125D0
     
          pp(8,IELEM)=(JCN31*uvw(2,n1) + JCN32*uvw(2,n2) + JCN33*uvw(2,n3) +&
                       JCN34*uvw(2,n4) + JCN35*uvw(2,n5) + JCN36*uvw(2,n6) +&
                       JCN37*uvw(2,n7) + JCN38*uvw(2,n8))*0.125D0

          pp(3,IELEM)=(JCN11*uvw(3,n1) + JCN12*uvw(3,n2) + JCN13*uvw(3,n3) +&
                       JCN14*uvw(3,n4) + JCN15*uvw(3,n5) + JCN16*uvw(3,n6) +&
                       JCN17*uvw(3,n7) + JCN18*uvw(3,n8))*0.125D0
     
          pp(6,IELEM)=(JCN21*uvw(3,n1) + JCN22*uvw(3,n2) + JCN23*uvw(3,n3) +&
                       JCN24*uvw(3,n4) + JCN25*uvw(3,n5) + JCN26*uvw(3,n6) +&
                       JCN27*uvw(3,n7) + JCN28*uvw(3,n8))*0.125D0
     
          pp(9,IELEM)=(JCN31*uvw(3,n1) + JCN32*uvw(3,n2) + JCN33*uvw(3,n3) +&
                       JCN34*uvw(3,n4) + JCN35*uvw(3,n5) + JCN36*uvw(3,n6) +&
                       JCN37*uvw(3,n7) + JCN38*uvw(3,n8))*0.125D0

!         diverg�ncia da velocidade (dVk/dXk):
       
          PNV(IELEM) = pp(1,IELEM) + pp(5,IELEM) + pp(9,IELEM) 

!         ***************************************************************************
!	      Componentes do tensor de tens�es viscosas do elemento IELEM tomados no
!         centro do memsmo. Considera-se que estas tens�es s�o as tens�es atuantes
!         na face de contorno!!
!         ***************************************************************************

!   *******************************************************************************
!   ********* CONSTANTES DE DIFUS�O (C�LCULO COEFICIENTES AERODIN�MICOS)
!   *******************************************************************************

!          IF(IndTurb.NE.0) THEN
			! TODO - Verificar se VDTurb � realmente 0 para escoamento laminar
            AUXv = ViscCin + VDTurb(IELEM)			!viscosidade total
            IF(AUXv.LT.1.00D0*ViscCin) THEN			!XXXXT 06.07.11 limiitando backscattering ANTES ERA: IF(AUX1.LT.0.0D0) AUX1 = ViscCin
															!XXXX 06.09.11 ALTERADO 0,5 PARA 0,05
              AUXv = 1.00D0*ViscCin
            end if

            COEF2= AUXv * RHOInf
            COEF3= ViscVol
!          end if
!   ********************************************************************************

          TAO(1,J)= 2.0D0*COEF2*pp(1,IELEM) + COEF3*PNV(IELEM)
          TAO(2,J)= 2.0D0*COEF2*pp(5,IELEM) + COEF3*PNV(IELEM)
          TAO(3,J)= 2.0D0*COEF2*pp(9,IELEM) + COEF3*PNV(IELEM)
          TAO(4,J)= COEF2*( pp(2,IELEM) + pp(4,IELEM) )
          TAO(5,J)= COEF2*( pp(7,IELEM) + pp(3,IELEM) )
          TAO(6,J)= COEF2*( pp(8,IELEM) + pp(6,IELEM) )

        END DO

!       Processo de suaviza��o das tens�es viscosas:

        DO J=0,NELEM
          T11ARG(J)=0.0D0
          T22ARG(J)=0.0D0
          T33ARG(J)=0.0D0
          T12ARG(J)=0.0D0
          T13ARG(J)=0.0D0
          T23ARG(J)=0.0D0
        end do


        DO J=1,NFCSX
          IF(J.GT.NFCN(NOB)) EXIT
          IELEM=IELCS(NOB,J)
          T11ARG(IELEM)= (TAO(1,J)*VOLU(IELEM))/8.0D0
          T22ARG(IELEM)= (TAO(2,J)*VOLU(IELEM))/8.0D0
          T33ARG(IELEM)= (TAO(3,J)*VOLU(IELEM))/8.0D0
          T12ARG(IELEM)= (TAO(4,J)*VOLU(IELEM))/8.0D0
          T13ARG(IELEM)= (TAO(5,J)*VOLU(IELEM))/8.0D0
          T23ARG(IELEM)= (TAO(6,J)*VOLU(IELEM))/8.0D0
        end do

!
!       Obten��o das componentes de tens�es viscosas suavizadas nos n�s de 
!       contorno s�lido;
!       Obten��o do vetor de tens�es totais (tens�es viscosas + press�o
!       hidrost�tica) nos n�s de contorno s�lido;
!       Obten��o do vetor de tens�es viscosas nos n�s de contorno s�lido. 

        DO I=1,NNCSX

          IF(I.GT.NNCN(NOB)) EXIT
          J=IBNOBJ(NOB,I)
		  
		  ! XXXXNEIB - Modificado para poder usar at� 12 elemeentos ao redor de um n�

          K10 = NEIBOR(1,J)
          K20 = NEIBOR(2,J)
          K30 = NEIBOR(3,J)
          K40 = NEIBOR(4,J)
          K50 = NEIBOR(5,J)
          K60 = NEIBOR(6,J)
          K70 = NEIBOR(7,J)
          K80 = NEIBOR(8,J)
		  K90 = NEIBOR(9,J)
          K100 = NEIBOR(10,J)
          K110 = NEIBOR(11,J)
          K120 = NEIBOR(12,J)
    
          T11S = ( T11ARG(K10)+T11ARG(K20)+T11ARG(K30)+T11ARG(K40)+T11ARG(K50)+T11ARG(K60)+ &
                   T11ARG(K70)+T11ARG(K80)+T11ARG(K90)+T11ARG(K100)+T11ARG(K110)+T11ARG(K120)) / mlum(J)

          T22S = ( T22ARG(K10)+T22ARG(K20)+T22ARG(K30)+T22ARG(K40)+T22ARG(K50)+T22ARG(K60)+ &
                   T22ARG(K70)+T22ARG(K80)+T22ARG(K90)+T22ARG(K100)+T22ARG(K110)+T22ARG(K120)) / mlum(J)
				   
          T33S = ( T33ARG(K10)+T33ARG(K20)+T33ARG(K30)+T33ARG(K40)+T33ARG(K50)+T33ARG(K60)+ &
                   T33ARG(K70)+T33ARG(K80)+T33ARG(K90)+T33ARG(K100)+T33ARG(K110)+T33ARG(K120)) / mlum(J)
				   
          T12S = ( T12ARG(K10)+T12ARG(K20)+T12ARG(K30)+T12ARG(K40)+T12ARG(K50)+T12ARG(K60)+ &
                   T12ARG(K70)+T12ARG(K80)+T12ARG(K90)+T12ARG(K100)+T12ARG(K110)+T12ARG(K120)) / mlum(J)

          T13S = ( T13ARG(K10)+T13ARG(K20)+T13ARG(K30)+T13ARG(K40)+T13ARG(K50)+T13ARG(K60)+ &
                   T13ARG(K70)+T13ARG(K80)+T13ARG(K90)+T13ARG(K100)+T13ARG(K110)+T13ARG(K120)) / mlum(J)

          T23S = ( T23ARG(K10)+T23ARG(K20)+T23ARG(K30)+T23ARG(K40)+T23ARG(K50)+T23ARG(K60)+ &
                   T23ARG(K70)+T23ARG(K80)+T23ARG(K90)+T23ARG(K100)+T23ARG(K110)+T23ARG(K120)) / mlum(J)
 
          VTV1(I)= -T11S*CSNOR1(NOB,I) - T12S*CSNOR2(NOB,I) - T13S*CSNOR3(NOB,I)
          VTV2(I)= -T12S*CSNOR1(NOB,I) - T22S*CSNOR2(NOB,I) - T23S*CSNOR3(NOB,I)
          VTV3(I)= -T13S*CSNOR1(NOB,I) - T23S*CSNOR2(NOB,I) - T33S*CSNOR3(NOB,I)

          VTT1(I)= -(T11S - uvw(4,J))*CSNOR1(NOB,I) - T12S*CSNOR2(NOB,I) - T13S*CSNOR3(NOB,I)
          VTT2(I)= -T12S*CSNOR1(NOB,I) -  (T22S - uvw(4,J))*CSNOR2(NOB,I) - T23S*CSNOR3(NOB,I)
          VTT3(I)= -T13S*CSNOR1(NOB,I) - T23S*CSNOR2(NOB,I)- (T33S - uvw(4,J))*CSNOR3(NOB,I)

        END DO

!       Obten��o dos coeficientes aerodin�micos:

        DO I=1,NNCSX

          IF(I.GT.NNCN(NOB)) EXIT
          J=IBNOBJ(NOB,I)
 
          DeltX = xyz(1,J) - Xobj(NOB)
          DeltY = xyz(2,J) - Yobj(NOB)
          DeltZ = xyz(3,J) - Zobj(NOB)
 
          F1 = VTT1(I)*ARSuav(NOB,I)
          F2 = VTT2(I)*ARSuav(NOB,I)
          F3 = VTT3(I)*ARSuav(NOB,I)

          Fx = Fx + F1
          Fy = Fy + F2 
          Fz = Fz + F3
 
!         Momento aerodin�mico: sinal positivo pela regra da m�o direita no sentido
!         dos eixos coordenados

          Mx = Mx + (F3*DeltY - F2*DeltZ)
          My = My + (F1*DeltZ - F3*DeltX)
          Mz = Mz + (F2*DeltX - F1*DeltY)

        end do
 
        CD = Fx	/ (Pdin*Dchar(NOB)*Lchar(NOB))
        CL = Fy	/ (Pdin*Dchar(NOB)*Lchar(NOB))
        CZ = Fz / (Pdin*Dchar(NOB)*Lchar(NOB))
        CMx = Mx	/ (Pdin*(Dchar(NOB)**2)*Lchar(NOB))
        CMy = My	/ (Pdin*(Dchar(NOB)**2)*Lchar(NOB))
        CMz = Mz	/ (Pdin*(Dchar(NOB)**2)*Lchar(NOB))

        NARQ=NARQ+1 	! 30, 36, 42, 48...
        WRITE(NARQ,*) tempo,Fx

        NARQ=NARQ+1 	! 31, 37, 43, 49...
        WRITE(NARQ,*) tempo,Fy

        NARQ=NARQ+1 	! 32, 38, 44, 50...
        WRITE(NARQ,*) tempo,Fz

        NARQ=NARQ+1 	! 33, 39, 45, 51...
        WRITE(NARQ,*) tempo,Mx

        NARQ=NARQ+1 	! 34, 40, 46, 52...
        WRITE(NARQ,*) tempo,My

        NARQ=NARQ+1 	! 35, 41, 47, 53...
        WRITE(NARQ,*) tempo,Mz

        NARQ=NARQ+1

      end do
	
	END IF

! CALCULO DA CONVERGENCIA TEMPORAL E TOMADA DE DECISIAO SOBRE A CONTINUIDADE        ! Ponto de gargalo no
! **************************************************************************		! c�digo
! OU FIM DO PROCESSAMENTO
! ************************

  SDETP=0.0D0
  SDTP=0.0D0
  
 
 !OPEN(68,FILE='verificacao',STATUS='UNKNOWN')
 !REWIND(68)
  IF (NNNRRR.GT.1) THEN
!
    DO I=1,NNM
      RES1=PRf(I)-PRi(I)
      RESCUA1=RES1*RES1
      SDETP=SDETP+RESCUA1
      
      PRES=PRi(I)
      PRESCUA=PRES*PRES
      SDTP=SDTP+PRESCUA
	  
	  !write(68,*) I, PRf(I), PRi(I), mlum(I)

    END DO
	
    SDETP=SQRT(SDETP/SDTP)

!   GRAVACAO DO ARQUIVO DE RESIDUOS
!   ---------------------------------
                    
    ICANT=NIR/4
    RNNN=FLOAT(NNNRRR)
    CANT=FLOAT(ICANT)
    RESS=RNNN/CANT
    IRESS=AINT(RESS)
    RESSE=FLOAT(IRESS)
    VARIND=RESS-RESSE

!   float - converte um n�mero inteiro em um real
!   aint - trunca o argumento

    IF (VARIND.EQ.0.0D0) WRITE(14,202) TEMPO,NNNRRR,SDETP

    IF ((SDETP.LE.TOLTPO)) INDTPO=INDTPO+1
  
END IF

!CLOSE(68)
!     ****************************************************
!     Final do ciclo de tempo
!     ****************************************************
end do 
!     ****************************************************
!     Final do ciclo de tempo
!     ****************************************************

CLOSE (14)
!IF(MNOBJ.NE.0) THEN
  !DO I=30,NOPF
CLOSE(30)
CLOSE(31)
CLOSE(32)
CLOSE(33)
CLOSE(34)
CLOSE(35)
  !end do
!end if

! **************************************************************************
! REGISTRO DAS VARIAVIES APOS O FINAL DO CICLO DE TEMPO
! **************************************************************************

NFILE=NFILE+1
TPOAC=TEMPO

! ARQUIVO COM TEMPO E PROXIMO NFILE
! ---------------------------------

!uvw = uvw_d; PRSuav = PRSuav_d; VtSuav = VtSuav_d

PTNAME(7:14)='.steady '
OPEN(2,FILE=PTNAME,STATUS='UNKNOWN')
REWIND (2)
 
NF1=NFILE/100+48
NF2=(NFILE-(NFILE/100)*100)/10+48
NF3=NFILE-(NFILE/10)*10+48
PTNAME(7:9)=CHAR(NF1)//CHAR(NF2)//CHAR(NF3)

PTNAME(10:14)='.v   '
OPEN(3,FILE=PTNAME,STATUS='UNKNOWN')
REWIND (3)

PTNAME(10:14)='.pr  '
OPEN(4,FILE=PTNAME,STATUS='UNKNOWN')
REWIND (4)

PTNAME(10:14)='.vts '							!!!! Habilitar posteriormente
OPEN(5,FILE=PTNAME,STATUS='UNKNOWN')
REWIND (5)

WRITE(2,909)NFILE,TEMPO

DO I=1,NNM
  WRITE(3,*) uvw(1,I),uvw(2,I),uvw(3,I)
  WRITE(4,*) uvw(4,I),PRSUAV(I)
  WRITE(5,*) VtSuav(I)
END DO

CLOSE(2)
CLOSE(3)
CLOSE(4)
CLOSE(5)									 !!!! Habilitar depois de fazer VTSuav

! **************************************************************************
! REGISTRO DAS VARIAVEIS DE CAMPO M�DIO
! *************************************************************************

Umed = Umed_d; Vmed = Vmed_d; Wmed = Wmed_d 
PRmed = PRmed_d; VTmed = VTmed_d; PRSmed = PRSmed_d

IF(NPASS.NE.NNAUX) THEN

  PTNAME(7:14)='.vm     '
  OPEN(3,FILE=PTNAME,STATUS='UNKNOWN')
  REWIND (3)

  PTNAME(7:14)='.prm    '
  OPEN(4,FILE=PTNAME,STATUS='UNKNOWN')
  REWIND (4)

  PTNAME(7:14)='.vtsm   '
  OPEN(5,FILE=PTNAME,STATUS='UNKNOWN')
  REWIND (5)

  DO I=1,NNM
    WRITE(3,*) Umed(I),Vmed(I),Wmed(I)
    WRITE(4,*) PRmed(I),PRSmed(I)
    WRITE(5,*) VTmed(I)							! Habilitar depois da implementa��o da turbul�ncia
  END DO

  CLOSE(3)
  CLOSE(4)
  CLOSE(5)
end if


CALL CPU_TIME(time_f)
WRITE(*,*)
WRITE(*,*) '**********************************************'
WRITE(*,*) 'Tempo total de execucao:',time_f - time_i, elapsed
WRITE(*,*) '**********************************************'

! **************************************************************************
! FORMATS
! *********************************

  101 FORMAT (3(D19.12))
  201 FORMAT (2(D19.12))
  301 FORMAT (D19.12)
  202 FORMAT (E15.7,I10,E15.7,E15.7,E15.7)
  303 FORMAT (I8)
  404 FORMAT (3(E12.5))
  505 FORMAT (8(I8))
  606 FORMAT (6(E12.5))
  707 FORMAT (3(D13.5,1X))
  808 FORMAT (10(E12.5))
  909 FORMAT (I3,E12.5)
  910 FORMAT ('Passo de Tempo:',I8,' Tempo: ',D10.3,x,'res P',D10.3,x,'Cd:',D10.3,x,'Cl:',D10.3,x)


end program CUDA_HEXA_IGOR



