  ! REWIND (2)
  ! DO I=1,LCONTCARA                                                        
    ! READ(2,*) IEL(I)
    ! II=8*(I-1)
    ! READ(2,*) AREAC(I),FCONTOR(II+1),FCONTOR(II+2),FCONTOR(II+3),&
              ! FCONTOR(II+4),FCONTOR(II+5),FCONTOR(II+6),FCONTOR(II+7),FCONTOR(II+8) 
  ! END DO
      
