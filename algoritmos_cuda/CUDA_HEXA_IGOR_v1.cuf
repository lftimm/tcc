ALLOCATE(uvw_d(4,NNOS), VOLU_d(NEMAX), pp_d(9,NEMAX), uvwprom_d(3,NEMAX), PNV_d(NEMaX), Gr1P_d(NEMAX), &
		 Gr2P_d(NEMAX), Gr3P_d(NEMAX))
		 
